generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id        String   @id @default(cuid())
  nombre    String
  email     String?  @unique
  password  String?
  rol       String   // "ADMIN" | "CHOFER"
  telefono  String?
  licencia  String?  // Clase de licencia ej "A-2", "A-4"
  activo    Boolean  @default(true)
  pushToken String?  // Expo push notification token
  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  solicitudes      Solicitud[]
  reportes         Reporte[]
  gruaId           String?
  grua             Grua?    @relation(fields: [gruaId], references: [id])
  historialEstados HistorialEstado[]

  @@index([rol])
  @@index([email])
}

model Grua {
  id          String   @id @default(cuid())
  patente     String   @unique
  marca       String
  modelo      String
  anio        Int?
  capacidad   String   // "25 ton", "50 ton"
  tipo        String   // "Pluma", "Telescopica", "Articulada"
  estado      String   @default("DISPONIBLE") // "DISPONIBLE", "EN_SERVICIO", "MANTENCION"
  creadoEn    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  choferes    Usuario[]
  solicitudes Solicitud[]
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String
  rut       String?
  telefono  String?
  direccion String?
  creadoEn  DateTime @default(now())
  updatedAt DateTime @updatedAt

  solicitudes Solicitud[]

  @@index([nombre])
  @@index([rut])
}

model Solicitud {
  id          String   @id @default(cuid())
  codigo      String   @unique // Ej "SOL-012"
  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  choferId    String?
  chofer      Usuario? @relation(fields: [choferId], references: [id])
  gruaId      String?
  grua        Grua?    @relation(fields: [gruaId], references: [id])
  tipo        String   // "Izaje", "Montaje", "Descarga", "Traslado", "Otro"
  descripcion String
  fecha       DateTime
  hora        String   // "Manana" o "Tarde"
  direccion   String
  estado      String   @default("NUEVA") // "NUEVA", "ASIGNADA", "COMPLETADA"
  creadoEn    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporte          Reporte?
  historialEstados HistorialEstado[]

  @@index([choferId])
  @@index([clienteId])
  @@index([estado])
  @@index([fecha])
}

model Reporte {
  id              String    @id @default(cuid())
  codigo          String    @unique // Ej "RPT-0041"
  numeroReporte   Int?      // Numero secuencial del reporte (ej: 34928)
  solicitudId     String    @unique
  solicitud       Solicitud @relation(fields: [solicitudId], references: [id])
  choferId        String
  chofer          Usuario   @relation(fields: [choferId], references: [id])
  fecha           DateTime
  horas           Float
  horasExtra      Float     @default(0)
  valorHora       Float     @default(60000) // Valor hora en pesos (ej: 60000, 65000)
  descripcion     String
  evidencia       String?   // JSON array de urls de fotos o vacio
  conAlzahombre   Boolean   @default(false)
  pagado          Boolean   @default(false)
  factura         Boolean   @default(false)
  estadoReporte   String    @default("sin factura") // "facturado", "sin factura", "ESPERA OC"
  monto           Float     @default(0)
  latitud         Float?
  longitud        Float?
  creadoEn        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([choferId])
  @@index([fecha])
  @@index([pagado])
}

model Tarifa {
  id            String   @id @default(cuid())
  nombre        String   @unique // "standard", "alzahombre"
  valorHora     Float    // 60000, 65000
  minimoHoras   Float    @default(3) // Minimo de horas cobradas
  activa        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model HistorialEstado {
  id           String    @id @default(cuid())
  solicitudId  String
  solicitud    Solicitud @relation(fields: [solicitudId], references: [id])
  estadoAnterior String?
  estadoNuevo  String
  nota         String?
  usuarioId    String?
  usuario      Usuario?  @relation(fields: [usuarioId], references: [id])
  creadoEn     DateTime  @default(now())

  @@index([solicitudId])
  @@index([creadoEn])
}
